# Application
APP_NAME=K8s Health Check
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Security
SECRET_KEY=your-secret-key-change-in-production

# Kubernetes
# For in-cluster: use https://kubernetes.default.svc
# For local dev: use your kubeconfig API server URL
K8S_APISERVER_URL=https://kubernetes.default.svc
K8S_SSL_VERIFY=true

# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=k8s_monitor
MYSQL_PASSWORD=changeme
MYSQL_DATABASE=k8s_monitor

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_TTL=30

# Collector
COLLECTOR_INTERVAL=15
